# Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=8080

# MongoDB Connection
# Local: mongodb://localhost:27017/sugrs
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/sugrs
MONGODB_URI=mongodb://localhost:27017/sugrs

# Google Gemini API Key (for AI features)
# Get free key from: https://ai.google.dev
GEMINI_API_KEY=your_gemini_api_key_here

# Fast2SMS API Key (for SMS notifications - optional)
# Get free key from: https://www.fast2sms.com
# Leave empty to run in simulation mode (SMS logged but not sent)
FAST2SMS_API_KEY=your_fast2sms_key_here

# JWT Secret (for authentication)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here

# Node Environment
NODE_ENV=development

